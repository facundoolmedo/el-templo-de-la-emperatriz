# ─────────────────────────────────────────────
# CONFIGURACIÓN DEL SERVIDOR
# Copiar este archivo como .env y completar
# ─────────────────────────────────────────────

# Puerto donde corre el servidor (default: 3000)
PORT=3000

# Secreto para firmar los tokens JWT
# Generá uno aleatorio en: https://www.uuidgenerator.net/
JWT_SECRET=cambia_esto_por_algo_muy_secreto_y_largo_123!

# Cuánto dura la sesión normal (sin "recordarme")
JWT_EXPIRES_IN=8h

# Cuánto dura la sesión con "recordarme"
JWT_REMEMBER_EXPIRES_IN=30d

# Email de la administradora (se crea al correr npm run setup)
ADMIN_EMAIL=luciana@temploemperatriz.com

# Contraseña de la administradora (CAMBIALA antes de hacer setup)
ADMIN_PASSWORD=MiContraseñaSegura123!

# URL base del sitio (para producción)
SITE_URL=http://localhost:3000
